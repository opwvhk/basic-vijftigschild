570 Q$= LEFT$(Q$,1）             :REM ALLEEN EERST KAR.
580 IF Q$ <> "H" THEN 610
590 X1 = X3
600 H = 1
610 IF 0$ < "L" THEN 640
620 X2 = X
630 H = 1
640 IF Q$ <› "J" THEN 670
650 H = 2
660 C$ = "GOED HE !!"
