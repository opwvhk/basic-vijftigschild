400 K = INT(K)
410 REM ** CONTROLE SPELER **
420 REM ** AANWIJZING = B$ **
430 H = 0
440 B$ = "JIJ MOET HOGER !"
450 IF K < G THEN 470
460 B$ = "JIJ MOET LAGER ! "
470 IF K <> G THEN 500
480 B$ = " INDERDAAD DAT WAS HET GETAL !"
