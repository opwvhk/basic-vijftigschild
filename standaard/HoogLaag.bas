260 N = 100                      :REM AANTAL GETALLEN
270 X1 = 1                       :REM ONDERGRENS
280 X2 = N + 1                   :REM BOVENGRENS
290 X3 = X1 + INT( (X2-X1) / 2)  :REM EERSTE GOK
